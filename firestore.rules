rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function getRole() { return getUserData().role; }
    function isApproved() { return isAuth() && getUserData().approved == true; }
    function isAdmin() { return isApproved() && (getRole() == 'admin' || getRole() == 'super_admin'); }
    function isAdminOrManager() { return isApproved() && (getRole() == 'super_admin' || getRole() == 'admin' || getRole() == 'manager'); }
    function isCoordinatorPlus() { return isApproved() && (getRole() == 'super_admin' || getRole() == 'admin' || getRole() == 'manager' || getRole() == 'coordinator'); }
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if (isAuth() && request.auth.uid == uid
        && request.resource.data.role in ['staff', 'engineer']) || isAdmin();
      allow update, delete: if isAdmin();
    }
    match /leads/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
    match /customers/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /installations/{id} { allow read: if isApproved(); allow create, update: if isAdminOrManager(); allow delete: if isAdmin(); }
    match /team/{id} { allow read: if isApproved(); allow create, update: if isAdminOrManager(); allow delete: if isAdmin(); }
    match /materials/{id} { allow read: if isApproved(); allow create, update: if isAdminOrManager(); allow delete: if isAdmin(); }
    match /ongoingWork/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
    match /income/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /expenses/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /reminders/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
    match /gallery/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /purchaseOrders/{id} { allow read: if isApproved(); allow create, update: if isAdminOrManager(); allow delete: if isAdmin(); }
    match /retailers/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /influencers/{id} { allow read: if isApproved(); allow create, update: if isCoordinatorPlus(); allow delete: if isAdmin(); }
    match /employeeTasks/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
    match /leadPOs/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
    match /bomTemplates/{id} { allow read: if isApproved(); allow create, update: if isAdminOrManager(); allow delete: if isAdmin(); }
    match /company/{id} { allow read: if isApproved(); allow write: if isAdmin(); }
    match /activityLog/{id} { allow read: if isApproved(); allow create: if isApproved(); allow delete: if isAdmin(); }
    match /notifications/{id} { allow read, create, update: if isApproved(); allow delete: if isAdmin(); }
  }
}
